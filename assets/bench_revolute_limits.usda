#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def "Mats"
    {
        def Material "Steel"
        {
            token outputs:surface.connect = </World/Mats/Steel/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.65, 0.67, 0.7)
                float inputs:metallic = 0
                float inputs:roughness = 0.4
                token outputs:surface
            }
        }

        def Material "Alum"
        {
            token outputs:surface.connect = </World/Mats/Alum/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.83, 0.87)
                float inputs:metallic = 0
                float inputs:roughness = 0.35
                token outputs:surface
            }
        }

        def Material "Rubber"
        {
            token outputs:surface.connect = </World/Mats/Rubber/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.03, 0.03, 0.03)
                float inputs:metallic = 0
                float inputs:roughness = 0.98
                token outputs:surface
            }
        }
    }

    def "RobotChain"
    {
        def Cylinder "Base" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 10
            rel material:binding = </World/Mats/Steel>
            double radius = 20
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "Link1" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 30
            rel material:binding = </World/Mats/Alum>
            double radius = 5
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 25, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "Link2" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 25
            rel material:binding = </World/Mats/Alum>
            double radius = 4
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 52, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "Link3" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 20
            rel material:binding = </World/Mats/Alum>
            double radius = 3
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 74, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Sphere "Gripper" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Rubber>
            double radius = 5
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 89, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def "Joints"
        {
            def PhysicsRevoluteJoint "ShoulderYaw"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/RobotChain/Base>
                rel physics:body1 = </World/RobotChain/Link1>
                float physics:lowerLimit = -90
                float physics:upperLimit = 90
            }

            def PhysicsRevoluteJoint "Elbow"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/RobotChain/Link1>
                rel physics:body1 = </World/RobotChain/Link2>
                float physics:lowerLimit = -10
                float physics:upperLimit = 220
            }

            def PhysicsRevoluteJoint "WristPitch"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/RobotChain/Link2>
                rel physics:body1 = </World/RobotChain/Link3>
                float physics:lowerLimit = -80
                float physics:upperLimit = 80
            }

            def PhysicsRevoluteJoint "WristRoll"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/RobotChain/Link3>
                rel physics:body1 = </World/RobotChain/Gripper>
                float physics:lowerLimit = -10
                float physics:upperLimit = 260
            }
        }
    }
}

