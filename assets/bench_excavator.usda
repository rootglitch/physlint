#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def "Mats"
    {
        def Material "Steel"
        {
            token outputs:surface.connect = </World/Mats/Steel/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.65, 0.67, 0.7)
                float inputs:metallic = 0
                float inputs:roughness = 0.4
                token outputs:surface
            }
        }

        def Material "Alum"
        {
            token outputs:surface.connect = </World/Mats/Alum/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.83, 0.87)
                float inputs:metallic = 0
                float inputs:roughness = 0.35
                token outputs:surface
            }
        }
    }

    def "Excavator"
    {
        def Cube "Chassis" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Steel>
            double size = 1
            double3 xformOp:scale = (60, 15, 40)
            double3 xformOp:translate = (0, 7.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "Cab" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Steel>
            double size = 1
            double3 xformOp:scale = (25, 25, 30)
            double3 xformOp:translate = (10, 32.5, 5)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "BoomArm" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 40
            rel material:binding = </World/Mats/Alum>
            double radius = 5
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (25, 55, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "StickArm" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 35
            rel material:binding = </World/Mats/Alum>
            double radius = 4
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (25, 92.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "Bucket" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Alum>
            double size = 1
            double3 xformOp:scale = (25, 15, 20)
            double3 xformOp:translate = (25, 117.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "BoomPiston" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Steel>
            double size = 1
            double3 xformOp:scale = (4, 10, 4)
            double3 xformOp:translate = (35, 40, 10)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "StickPiston" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Steel>
            double size = 1
            double3 xformOp:scale = (4, 8, 4)
            double3 xformOp:translate = (35, 77, 8)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def "Joints"
        {
            def PhysicsPrismaticJoint "BoomCylinder"
            {
                uniform token physics:axis = "Y"
                rel physics:body0 = </World/Excavator/BoomArm>
                rel physics:body1 = </World/Excavator/BoomPiston>
                float physics:lowerLimit = 0
                float physics:upperLimit = 150
            }

            def PhysicsPrismaticJoint "ArmCylinder"
            {
                uniform token physics:axis = "Y"
                rel physics:body0 = </World/Excavator/StickArm>
                rel physics:body1 = </World/Excavator/StickPiston>
                float physics:lowerLimit = 0
                float physics:upperLimit = 120
            }

            def PhysicsRevoluteJoint "BucketCurl"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Excavator/StickArm>
                rel physics:body1 = </World/Excavator/Bucket>
                float physics:lowerLimit = -45
                float physics:upperLimit = 135
            }

            def PhysicsRevoluteJoint "CabSwing"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Excavator/Chassis>
                rel physics:body1 = </World/Excavator/Cab>
                float physics:lowerLimit = -170
                float physics:upperLimit = 170
            }
        }
    }
}

