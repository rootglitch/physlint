                                                }

                                                over "Box_4" (
                                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                                )
                                                {
                                                    rel material:binding:physics = </panda/Physics/PhysicsMaterial>
                                                    uniform int mjc:group = 3
                                                    float newton:contactGap = 0
                                                    float physics:density = 1000
                                                }

                                                def PhysicsPrismaticJoint "finger_joint1" (
                                                    prepend apiSchemas = ["MjcJointAPI"]
                                                )
                                                {
                                                    uniform double mjc:armature = 0.1
                                                    uniform double mjc:damping = 1
                                                    uniform token physics:axis = "Y"
                                                    rel physics:body0 = </panda/Geometry/link0/link1/link2/link3/link4/link5/link6/link7/hand>
                                                    rel physics:body1 = </panda/Geometry/link0/link1/link2/link3/link4/link5/link6/link7/hand/left_finger>
                                                    point3f physics:localPos0 = (6.938894e-18, 0, 0.0584)
                                                    point3f physics:localPos1 = (0, 0, 0)
                                                    quatf physics:localRot0 = (1, 0, 0, 0)
                                                    quatf physics:localRot1 = (1, 0, 0, 0)
                                                    float physics:lowerLimit = 0
                                                    float physics:upperLimit = 0.04
                                                }
                                            }

                                            def "right_finger" (
                                                prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
                                            )
                                            {
                                                point3f physics:centerOfMass = (0, 0, 0)
                                                float3 physics:diagonalInertia = (0.000002375, 0.000002375, 7.5e-7)
                                                float physics:mass = 0.015
                                                quatf physics:principalAxes = (1, 0, 0, 0)

                                                over "finger_0_1" (
                                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMeshCollisionAPI", "NewtonMeshCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                                )
                                                {
                                                    rel material:binding:physics = </panda/Physics/PhysicsMaterial>
                                                    uniform int mjc:group = 3
                                                    float newton:contactGap = 0
                                                    uniform token physics:approximation = "convexHull"
                                                    float physics:density = 1000
                                                }

                                                over "Box" (
                                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                                )
                                                {
                                                    rel material:binding:physics = </panda/Physics/PhysicsMaterial>
                                                    uniform int mjc:group = 3
                                                    float newton:contactGap = 0
                                                    float physics:density = 1000
                                                }

                                                over "Box_1" (
                                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                                )
                                                {
                                                    rel material:binding:physics = </panda/Physics/PhysicsMaterial>
                                                    uniform int mjc:group = 3
                                                    float newton:contactGap = 0
                                                    float physics:density = 1000
                                                }

                                                over "Box_2" (
                                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                                )
                                                {
                                                    rel material:binding:physics = </panda/Physics/PhysicsMaterial>
                                                    uniform int mjc:group = 3
                                                    float newton:contactGap = 0
                                                    float physics:density = 1000
                                                }

                                                over "Box_3" (
                                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                                )
                                                {
                                                    rel material:binding:physics = </panda/Physics/PhysicsMaterial>
                                                    uniform int mjc:group = 3
                                                    float newton:contactGap = 0
                                                    float physics:density = 1000
                                                }

                                                over "Box_4" (
                                                    prepend apiSchemas = ["PhysicsCollisionAPI", "NewtonCollisionAPI", "MjcCollisionAPI", "PhysicsMassAPI", "MaterialBindingAPI"]
                                                )
                                                {
                                                    rel material:binding:physics = </panda/Physics/PhysicsMaterial>
                                                    uniform int mjc:group = 3
                                                    float newton:contactGap = 0
                                                    float physics:density = 1000
                                                }

                                                def PhysicsPrismaticJoint "finger_joint2" (
                                                    prepend apiSchemas = ["MjcJointAPI"]
                                                )
                                                {
                                                    uniform double mjc:armature = 0.1
                                                    uniform double mjc:damping = 1
                                                    uniform token physics:axis = "Y"
                                                    rel physics:body0 = </panda/Geometry/link0/link1/link2/link3/link4/link5/link6/link7/hand>
                                                    rel physics:body1 = </panda/Geometry/link0/link1/link2/link3/link4/link5/link6/link7/hand/right_finger>
                                                    point3f physics:localPos0 = (6.938894e-18, 0, 0.0584)
                                                    point3f physics:localPos1 = (0, 0, 0)
                                                    quatf physics:localRot0 = (-1.6653345e-16, -6.674186e-17, -1.1669192e-16, -1)
                                                    quatf physics:localRot1 = (1, 0, 0, 0)
                                                    float physics:lowerLimit = 0
                                                    float physics:upperLimit = 0.04
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

def PhysicsScene "PhysicsScene" (
    prepend apiSchemas = ["NewtonSceneAPI", "MjcSceneAPI"]
)
{
    uniform token mjc:compiler:angle = "radian"
    uniform token mjc:option:integrator = "implicitfast"
    uniform int newton:maxSolverIterations = 100
    uniform int newton:timeStepsPerSecond = 500
    vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 9.81
}

