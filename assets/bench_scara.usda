#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def "Mats"
    {
        def Material "Steel"
        {
            token outputs:surface.connect = </World/Mats/Steel/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.65, 0.67, 0.7)
                float inputs:metallic = 0
                float inputs:roughness = 0.4
                token outputs:surface
            }
        }

        def Material "Alum"
        {
            token outputs:surface.connect = </World/Mats/Alum/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.83, 0.87)
                float inputs:metallic = 0
                float inputs:roughness = 0.35
                token outputs:surface
            }
        }

        def Material "Rubber"
        {
            token outputs:surface.connect = </World/Mats/Rubber/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.03, 0.03, 0.03)
                float inputs:metallic = 0
                float inputs:roughness = 0.98
                token outputs:surface
            }
        }
    }

    def "Scara"
    {
        def Cube "Base" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Steel>
            double size = 1
            double3 xformOp:scale = (20, 8, 20)
            double3 xformOp:translate = (0, 4, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "ArmLink1" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Alum>
            double size = 1
            double3 xformOp:scale = (35, 6, 6)
            double3 xformOp:translate = (17.5, 15, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "ArmLink2" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Alum>
            double size = 1
            double3 xformOp:scale = (25, 6, 6)
            double3 xformOp:translate = (47.5, 15, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "ZColumn" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 60
            rel material:binding = </World/Mats/Alum>
            double radius = 3
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (65, 45, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "ZCarriage" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Alum>
            double size = 1
            double3 xformOp:scale = (8, 15, 8)
            double3 xformOp:translate = (65, 22.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Sphere "Tool" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Rubber>
            double radius = 4
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (65, 11, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def "Joints"
        {
            def PhysicsRevoluteJoint "Joint1"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Scara/Base>
                rel physics:body1 = </World/Scara/ArmLink1>
                float physics:lowerLimit = -150
                float physics:upperLimit = 150
            }

            def PhysicsRevoluteJoint "Joint2"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Scara/ArmLink1>
                rel physics:body1 = </World/Scara/ArmLink2>
                float physics:lowerLimit = -10
                float physics:upperLimit = 210
            }

            def PhysicsPrismaticJoint "ZTravel"
            {
                uniform token physics:axis = "Y"
                rel physics:body0 = </World/Scara/ZColumn>
                rel physics:body1 = </World/Scara/ZCarriage>
                float physics:lowerLimit = 0
                float physics:upperLimit = 200
            }

            def PhysicsRevoluteJoint "ToolRotate"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Scara/ZCarriage>
                rel physics:body1 = </World/Scara/Tool>
                float physics:lowerLimit = -175
                float physics:upperLimit = 175
            }
        }
    }
}

