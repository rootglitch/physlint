#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def "Mats"
    {
        def Material "Steel"
        {
            token outputs:surface.connect = </World/Mats/Steel/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.65, 0.67, 0.7)
                float inputs:metallic = 0
                float inputs:roughness = 0.4
                token outputs:surface
            }
        }

        def Material "Alum"
        {
            token outputs:surface.connect = </World/Mats/Alum/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.83, 0.87)
                float inputs:metallic = 0
                float inputs:roughness = 0.35
                token outputs:surface
            }
        }

        def Material "Concrete"
        {
            token outputs:surface.connect = </World/Mats/Concrete/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.55, 0.53, 0.5)
                float inputs:metallic = 0
                float inputs:roughness = 0.9
                token outputs:surface
            }
        }
    }

    def "Assembly"
    {
        def Cube "RotorBase" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Steel>
            double size = 1
            double3 xformOp:scale = (20, 5, 20)
            double3 xformOp:translate = (0, 2.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "ArmPivot" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 25
            rel material:binding = </World/Mats/Alum>
            double radius = 4
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 19.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "SwingFixture" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Concrete>
            double size = 1
            double3 xformOp:scale = (15, 5, 15)
            double3 xformOp:translate = (50, 2.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "SwingArm" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 20
            rel material:binding = </World/Mats/Alum>
            double radius = 3
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (50, 15, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "HalfBase" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Steel>
            double size = 1
            double3 xformOp:scale = (10, 8, 10)
            double3 xformOp:translate = (-50, 4, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "HalfArm" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 20
            rel material:binding = </World/Mats/Alum>
            double radius = 3
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (-50, 18, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def "Joints"
        {
            def PhysicsRevoluteJoint "WideSwing"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Assembly/RotorBase>
                rel physics:body1 = </World/Assembly/ArmPivot>
                float physics:lowerLimit = -200
                float physics:upperLimit = 200
            }

            def PhysicsRevoluteJoint "TightPivot"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Assembly/SwingFixture>
                rel physics:body1 = </World/Assembly/SwingArm>
                float physics:lowerLimit = -25
                float physics:upperLimit = 25
            }

            def PhysicsRevoluteJoint "HalfRotation"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Assembly/HalfBase>
                rel physics:body1 = </World/Assembly/HalfArm>
                float physics:lowerLimit = -90
                float physics:upperLimit = 90
            }
        }
    }
}

