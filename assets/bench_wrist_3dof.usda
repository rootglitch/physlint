#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def "Mats"
    {
        def Material "Steel"
        {
            token outputs:surface.connect = </World/Mats/Steel/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.65, 0.67, 0.7)
                float inputs:metallic = 0
                float inputs:roughness = 0.4
                token outputs:surface
            }
        }

        def Material "Alum"
        {
            token outputs:surface.connect = </World/Mats/Alum/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.83, 0.87)
                float inputs:metallic = 0
                float inputs:roughness = 0.35
                token outputs:surface
            }
        }

        def Material "Rubber"
        {
            token outputs:surface.connect = </World/Mats/Rubber/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.03, 0.03, 0.03)
                float inputs:metallic = 0
                float inputs:roughness = 0.98
                token outputs:surface
            }
        }
    }

    def "Wrist"
    {
        def Cylinder "YawBase" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 10
            rel material:binding = </World/Mats/Steel>
            double radius = 8
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "YawLink" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 15
            rel material:binding = </World/Mats/Alum>
            double radius = 4
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 17.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "PitchLink" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 12
            rel material:binding = </World/Mats/Alum>
            double radius = 3.5
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 31, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "RollLink" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 20
            rel material:binding = </World/Mats/Alum>
            double radius = 3
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 47, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "ToolBody" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Rubber>
            double size = 1
            double3 xformOp:scale = (6, 8, 6)
            double3 xformOp:translate = (0, 61, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def "Joints"
        {
            def PhysicsRevoluteJoint "Yaw"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Wrist/YawBase>
                rel physics:body1 = </World/Wrist/YawLink>
                float physics:lowerLimit = -175
                float physics:upperLimit = 175
            }

            def PhysicsRevoluteJoint "Pitch"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Wrist/YawLink>
                rel physics:body1 = </World/Wrist/PitchLink>
                float physics:lowerLimit = -90
                float physics:upperLimit = 90
            }

            def PhysicsRevoluteJoint "Roll"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Wrist/PitchLink>
                rel physics:body1 = </World/Wrist/RollLink>
                float physics:lowerLimit = -10
                float physics:upperLimit = 370
            }

            def PhysicsPrismaticJoint "ToolGrip"
            {
                uniform token physics:axis = "Y"
                rel physics:body0 = </World/Wrist/RollLink>
                rel physics:body1 = </World/Wrist/ToolBody>
                float physics:lowerLimit = -10
                float physics:upperLimit = 80
            }
        }
    }
}

