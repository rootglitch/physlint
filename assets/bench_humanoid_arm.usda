#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def "Mats"
    {
        def Material "Alum"
        {
            token outputs:surface.connect = </World/Mats/Alum/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.83, 0.87)
                float inputs:metallic = 0
                float inputs:roughness = 0.35
                token outputs:surface
            }
        }

        def Material "Rubber"
        {
            token outputs:surface.connect = </World/Mats/Rubber/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.03, 0.03, 0.03)
                float inputs:metallic = 0
                float inputs:roughness = 0.98
                token outputs:surface
            }
        }
    }

    def "Arm"
    {
        def Cylinder "ShoulderLink" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 12
            rel material:binding = </World/Mats/Alum>
            double radius = 7
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 6, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "UpperArm" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 30
            rel material:binding = </World/Mats/Alum>
            double radius = 5
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 27, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "Forearm" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 25
            rel material:binding = </World/Mats/Alum>
            double radius = 4
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 54, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "WristLink" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 8
            rel material:binding = </World/Mats/Alum>
            double radius = 3
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 73, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Sphere "Hand" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Rubber>
            double radius = 6
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 83, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def "Joints"
        {
            def PhysicsRevoluteJoint "ShoulderFlexion"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Arm/ShoulderLink>
                rel physics:body1 = </World/Arm/UpperArm>
                float physics:lowerLimit = -60
                float physics:upperLimit = 170
            }

            def PhysicsRevoluteJoint "ShoulderAbduct"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Arm/ShoulderLink>
                rel physics:body1 = </World/Arm/UpperArm>
                float physics:lowerLimit = -45
                float physics:upperLimit = 200
            }

            def PhysicsRevoluteJoint "ShoulderRotation"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Arm/ShoulderLink>
                rel physics:body1 = </World/Arm/UpperArm>
                float physics:lowerLimit = -90
                float physics:upperLimit = 90
            }

            def PhysicsRevoluteJoint "ElbowFlexion"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Arm/UpperArm>
                rel physics:body1 = </World/Arm/Forearm>
                float physics:lowerLimit = 0
                float physics:upperLimit = 145
            }

            def PhysicsRevoluteJoint "WristFlexion"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Arm/Forearm>
                rel physics:body1 = </World/Arm/WristLink>
                float physics:lowerLimit = -70
                float physics:upperLimit = 70
            }

            def PhysicsRevoluteJoint "WristSupination"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Arm/WristLink>
                rel physics:body1 = </World/Arm/Hand>
                float physics:lowerLimit = -90
                float physics:upperLimit = 200
            }
        }
    }
}

