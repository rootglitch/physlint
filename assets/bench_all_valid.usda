#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def "Mats"
    {
        def Material "Steel"
        {
            token outputs:surface.connect = </World/Mats/Steel/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.65, 0.67, 0.7)
                float inputs:metallic = 0
                float inputs:roughness = 0.4
                token outputs:surface
            }
        }

        def Material "Alum"
        {
            token outputs:surface.connect = </World/Mats/Alum/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.83, 0.87)
                float inputs:metallic = 0
                float inputs:roughness = 0.35
                token outputs:surface
            }
        }
    }

    def "Robot"
    {
        def Cube "Base" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </World/Mats/Steel>
            double size = 1
            double3 xformOp:scale = (25, 8, 25)
            double3 xformOp:translate = (0, 4, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "Link1" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 35
            rel material:binding = </World/Mats/Alum>
            double radius = 5
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 25.5, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "Link2" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 30
            rel material:binding = </World/Mats/Alum>
            double radius = 4
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 58, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "Link3" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 20
            rel material:binding = </World/Mats/Alum>
            double radius = 3
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 83, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cylinder "ToolHead" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            double height = 10
            rel material:binding = </World/Mats/Alum>
            double radius = 2
            double3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (0, 98, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def "Joints"
        {
            def PhysicsRevoluteJoint "BaseTurn"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Robot/Base>
                rel physics:body1 = </World/Robot/Link1>
                float physics:lowerLimit = -90
                float physics:upperLimit = 90
            }

            def PhysicsRevoluteJoint "ShoulderLift"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Robot/Link1>
                rel physics:body1 = </World/Robot/Link2>
                float physics:lowerLimit = -30
                float physics:upperLimit = 120
            }

            def PhysicsRevoluteJoint "ElbowBend"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Robot/Link2>
                rel physics:body1 = </World/Robot/Link3>
                float physics:lowerLimit = 0
                float physics:upperLimit = 135
            }

            def PhysicsRevoluteJoint "WristTilt"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Robot/Link3>
                rel physics:body1 = </World/Robot/ToolHead>
                float physics:lowerLimit = -60
                float physics:upperLimit = 60
            }

            def PhysicsRevoluteJoint "ToolSpin"
            {
                uniform token physics:axis = "Z"
                rel physics:body0 = </World/Robot/ToolHead>
                rel physics:body1 = </World/Robot/Link3>
                float physics:lowerLimit = -175
                float physics:upperLimit = 175
            }
        }
    }
}

